# ─────────────────────────────────────────────────────────
#  CTF AI Agent — Environment Variables
#  Copy to .env and fill in values. Run ctf-setup.sh to do
#  this automatically.
# ─────────────────────────────────────────────────────────

# ── LLM Backend ───────────────────────────────────────────
# Choose ONE backend for Hermes. Uncomment the matching block.

# Option A: Local Ollama  (default — fully offline, free)
#   Install: https://ollama.com
#   Pull:    ollama pull nous-hermes3
HERMES_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nous-hermes3          # or hermes3:8b, hermes3:70b

# Option B: OpenRouter  (https://openrouter.ai)
# HERMES_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Option C: Together AI  (https://together.ai)
# HERMES_BACKEND=together
# TOGETHER_API_KEY=...
# TOGETHER_MODEL=NousResearch/Hermes-3-Llama-3.1-405B-Turbo

# ── Agent behaviour ───────────────────────────────────────
# These are defaults. Each profile's config.yaml overrides them.
MAX_ITERATIONS=30           # max tool-call rounds per challenge
AGENT_TEMPERATURE=0.1       # low = more deterministic reasoning

# ── Safety ────────────────────────────────────────────────
# Comma-separated patterns that bash_exec will refuse to run
BASH_DENY_PATTERNS=rm -rf /,mkfs,:(){:|:&};:

# ── Command Center server ──────────────────────────────────
# Shared secret all 23 team members use to authenticate
CTF_TOKEN=change-me-before-defcon
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# URL the Telegram bot uses to reach the server
# Set to your VPS/machine IP when running remotely
SERVER_URL=http://localhost:8000

# ── Telegram bot (Singapore team) ─────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
